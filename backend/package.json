{
  "name": "zlpix-premiado-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
  "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
  "build": "tsc -p tsconfig.build.json",
  "start": "node dist/server.js",
  "prebuild": "npm install --save-dev @types/node @types/express @types/cors @types/qrcode"
}
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "qrcode": "^1.5.3",
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/qrcode": "^1.5.5",
    "prisma": "^5.22.0"
  }
}
