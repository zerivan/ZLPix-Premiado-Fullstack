{
  "name": "zlpix-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "license": "MIT",
  "engines": {
    "node": "22.16.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "fix": "bash scripts/fix_render.sh",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:force": "prisma migrate dev --name init --skip-seed --create-only",
    "build": "npm run migrate:deploy && prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "5.15.1",
    "@types/node": "^18.19.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "prisma": "5.15.1",
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}