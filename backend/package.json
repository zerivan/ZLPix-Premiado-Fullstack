{
  "name": "zlpix-backend",
  "version": "1.0.0",
  "description": "ZLPix Premiado - Backend API (Express + Prisma + Neon + Render)",
  "main": "dist/server.js",

  "scripts": {
    "dev": "ts-node src/server.ts",
    "migrate:deploy": "npx prisma migrate deploy",
    "db:sync": "npx prisma db push",
    "build": "rm -rf dist && npx prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js"
  },

  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.4.5",
    "@prisma/client": "5.15.0"
  },

  "devDependencies": {
    "prisma": "5.15.0",
    "typescript": "^5.6.3",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.5.2",
    "ts-node": "^10.9.2"
  },

  "engines": {
    "node": "22.16.0",
    "npm": "10.x"
  },

  "license": "MIT"
}