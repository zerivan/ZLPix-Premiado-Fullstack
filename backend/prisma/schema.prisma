// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 👤 Usuário
model Usuario {
  id        Int       @id @default(autoincrement())
  nome      String
  email     String    @unique
  senha     String
  criadoEm  DateTime  @default(now())
  bilhetes  Bilhete[]
}

// 🎫 Bilhete
model Bilhete {
  id          Int          @id @default(autoincrement())
  numeros     String
  criadoEm    DateTime      @default(now())
  confirmado  Boolean       @default(false)
  pago        Boolean       @default(false)
  usuarioId   Int?
  usuario     Usuario?      @relation(fields: [usuarioId], references: [id])
  pagamento   Pagamento?    @relation("BilhetePagamento")
}

// 💰 Pagamento
model Pagamento {
  id          Int       @id @default(autoincrement())
  chavePix    String
  valor       Float
  status      String    @default("pendente") // pendente | pago | cancelado
  criadoEm    DateTime  @default(now())
  bilheteId   Int
  bilhete     Bilhete   @relation("BilhetePagamento", fields: [bilheteId], references: [id])
}  status      String    @default("pendente") // pendente | pago | cancelado
  criadoEm    DateTime  @default(now())
  bilheteId   Int
  bilhete     Bilhete   @relation(fields: [bilheteId], references: [id])
}
