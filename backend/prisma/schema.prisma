generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Pix {
  id        Int      @id @default(autoincrement())
  chave     String
  valor     Float
  criadoEm  DateTime @default(now())
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  phone        String?
  pixKey       String?
  passwordHash String
  createdAt    DateTime @default(now())
}