// backend/prisma/schema.prisma

// 🔧 Configuração do Prisma Client
generator client {
  provider = "prisma-client-js"
}

// 💾 Banco de dados SQLite
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 🧾 Modelo de Usuário (para login e controle de apostas)
model Usuario {
  id        Int       @id @default(autoincrement())
  nome      String
  email     String    @unique
  senha     String
  criadoEm  DateTime  @default(now())
  bilhetes  Bilhete[]
}

// 🎫 Modelo de Bilhete de aposta
model Bilhete {
  id         Int       @id @default(autoincrement())
  numeros    String    // ex: "03,15,88"
  criadoEm   DateTime  @default(now())
  confirmado Boolean   @default(false)
  pago       Boolean   @default(false)
  usuarioId  Int?
  usuario    Usuario?  @relation(fields: [usuarioId], references: [id])
}

// 💰 Modelo de Pagamento PIX
model Pagamento {
  id          Int       @id @default(autoincrement())
  chavePix    String
  valor       Float
  status      String    @default("pendente") // pendente | pago | cancelado
  criadoEm    DateTime  @default(now())
  bilheteId   Int
  bilhete     Bilhete   @relation(fields: [bilheteId], references: [id])
}
