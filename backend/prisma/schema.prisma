generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id           BigInt   @id @default(autoincrement())
  name         String
  email        String   @unique
  phone        String?
  pixKey       String?
  passwordHash String
  createdAt    DateTime @default(now())
}

model Admins {
  id           BigInt   @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}