generator client {
  provider   = "prisma-client-js"
  engineType = "node-api"
}

datasource db {
  provider = "postgresql"
  // NÃO usa mais URL aqui
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  phone        String?
  pixKey       String?
  passwordHash String
  createdAt    DateTime @default(now())
}