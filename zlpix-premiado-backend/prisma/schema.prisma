generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Bilhete {
  id        Int      @id @default(autoincrement())
  numeros   String
  usuario   String
  criadoEm  DateTime @default(now())
  pago      Boolean  @default(false)
}
